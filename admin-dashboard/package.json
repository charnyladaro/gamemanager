{
  "name": "gamemanager-admin",
  "version": "1.0.0",
  "description": "GameManager Admin Dashboard - Manage users, games, and system settings",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "package": "electron-packager . GameManagerAdmin --platform=win32 --arch=x64 --out=../release --overwrite"
  },
  "keywords": [
    "gamemanager",
    "admin",
    "dashboard"
  ],
  "author": "GameManager Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {},
  "build": {
    "appId": "com.gamemanager.admin",
    "productName": "GameManagerAdmin",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "dir",
      "sign": false
    }
  }
}
