# ============================================================================
# GameManager Environment Variables
# ============================================================================
# This is an example configuration file for GameManager backend.
# Copy this file to .env and update with your actual values.
#
# IMPORTANT: Never commit .env to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# SECURITY KEYS (REQUIRED)
# ----------------------------------------------------------------------------
# Generate your own secret keys using:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# CRITICAL: Change these values in production!
# ----------------------------------------------------------------------------

# Flask secret key (used for session encryption)
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# JWT secret key (used for token authentication)
JWT_SECRET_KEY=change-this-to-a-different-random-secret-key-in-production

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
# Local development uses SQLite by default.
# Production should use PostgreSQL (provided by Render/Railway).
#
# Format for PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/database
#
# Leave commented for local development (uses SQLite)
# ----------------------------------------------------------------------------

# DATABASE_URL=sqlite:///gamemanager.db
# DATABASE_URL=postgresql://user:password@host:5432/gamemanager

# ----------------------------------------------------------------------------
# DEPLOYMENT URL CONFIGURATION (for Hybrid Architecture)
# ----------------------------------------------------------------------------
# Configure these for production deployment:
# - API_BASE_URL: Where your Flask backend API is hosted (Render.com)
# - STORAGE_BASE_URL: Where files are served from (Cloudflare Tunnel)
#
# LOCAL DEVELOPMENT (leave blank or comment out):
#   API_BASE_URL=
#   STORAGE_BASE_URL=
#
# PRODUCTION SETUP:
#   API_BASE_URL=https://gamemanager-api.onrender.com
#   STORAGE_BASE_URL=https://your-tunnel-name.trycloudflare.com
#
# IMPORTANT:
# - Do NOT include trailing slashes
# - Use HTTPS in production
# - Cloudflare Tunnel URL must match your tunnel configuration
# ----------------------------------------------------------------------------

# API Base URL - where Flask backend is hosted
# Leave blank for local development (auto-detects from request)
API_BASE_URL=

# Storage Base URL - where uploads/files are served from
# Leave blank for local development (uses same as API_BASE_URL)
# In production, set this to your Cloudflare Tunnel URL
STORAGE_BASE_URL=

# ----------------------------------------------------------------------------
# RAWG API (OPTIONAL - for automatic game cover fetching)
# ----------------------------------------------------------------------------
# Get your free API key at https://rawg.io/apidocs
# This is used to automatically fetch game cover images.
# ----------------------------------------------------------------------------

RAWG_API_KEY=your-rawg-api-key-here

# ----------------------------------------------------------------------------
# GCASH PAYMENT CONFIGURATION (REQUIRED for payments)
# ----------------------------------------------------------------------------
# Your GCash registered mobile number
# Format: 09XXXXXXXXX (Philippine mobile number)
# ----------------------------------------------------------------------------

GCASH_MERCHANT_NUMBER=09123456789

# ----------------------------------------------------------------------------
# TELEGRAM BOT CONFIGURATION (REQUIRED for notifications)
# ----------------------------------------------------------------------------
# Get bot token from @BotFather on Telegram
# Get chat ID by messaging your bot and checking:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
#
# See TELEGRAM_BOT_SETUP.md for detailed instructions
# ----------------------------------------------------------------------------

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Admin chat ID (where payment notifications are sent)
TELEGRAM_ADMIN_CHAT_ID=123456789

# ----------------------------------------------------------------------------
# OPTIONAL CONFIGURATION
# ----------------------------------------------------------------------------

# Maximum upload file size (default: 500GB)
# MAX_CONTENT_LENGTH=500GB

# Server host and port (for local development)
# HOST=0.0.0.0
# PORT=5000

# ----------------------------------------------------------------------------
# DEPLOYMENT EXAMPLES
# ----------------------------------------------------------------------------
#
# Example 1: Local Development
# -----------------------------
# SECRET_KEY=dev-secret-key
# JWT_SECRET_KEY=dev-jwt-secret
# API_BASE_URL=
# STORAGE_BASE_URL=
# (Everything runs on localhost:5000)
#
# Example 2: Full Production (Render + Cloudflare)
# -------------------------------------------------
# SECRET_KEY=<generated-secret>
# JWT_SECRET_KEY=<generated-secret>
# API_BASE_URL=https://gamemanager-api.onrender.com
# STORAGE_BASE_URL=https://my-tunnel.trycloudflare.com
# DATABASE_URL=postgresql://user:pass@host/db
# TELEGRAM_BOT_TOKEN=8519027780:AAG...
# TELEGRAM_ADMIN_CHAT_ID=7423168309
#
# Example 3: Staging/Testing
# ---------------------------
# SECRET_KEY=<generated-secret>
# JWT_SECRET_KEY=<generated-secret>
# API_BASE_URL=https://gamemanager-staging.onrender.com
# STORAGE_BASE_URL=http://localhost:5000
# (API in cloud, files served locally)
#
# ============================================================================
